# 🔐 EXEMPLE DE FICHIER DE CONFIGURATION
# Copiez ce fichier en .env et remplissez avec vos vraies valeurs
# NE COMMITEZ JAMAIS LE FICHIER .env SUR GIT !

# Base de données PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=medo_db
DB_USER=admin
DB_PASS=VOTRE_MOT_DE_PASSE_ICI

# Redis (Cache)
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT Secret (minimum 32 caractères)
JWT_SECRET=votre_secret_jwt_de_minimum_32_caracteres_ici

# Environnement
SPRING_PROFILES_ACTIVE=dev
